    {
      "name": "Update Order",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Budi Santoso\",\n  \"items\": [\n    {\n      \"productName\": \"Orange\",\n      \"quantity\": 2,\n      \"unitPrice\": 1.00\n    }\n  ]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders/{{orderId}}",
          "host": ["http", "localhost"],
          "port": "8080",
          "path": ["api", "orders", "{{orderId}}"]
        },
        "description": "Updates customer name and items. Items cannot be modified if order status is PAID or beyond. Replace orderId with a valid order UUID."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Customer name updated\", function () {",
              "    pm.expect(pm.response.json().customerName).to.eql(\"Budi Santoso\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Pay Order",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PAID\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders/{{orderId}}/status",
          "host": ["http", "localhost"],
          "port": "8080",
          "path": ["api", "orders", "{{orderId}}", "status"]
        },
        "description": "Transitions an order from CREATED to PAID. Replace orderId with a valid order UUID in CREATED status."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Status is PAID\", function () {",
              "    pm.expect(pm.response.json().status).to.eql(\"PAID\");",
              "});"
            ]
          }
        }
      ]
    },
