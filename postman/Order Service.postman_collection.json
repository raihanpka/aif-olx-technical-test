          "raw": "{\n  \"status\": \"SHIPPED\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders/{{orderId}}/status",
          "host": ["http", "localhost"],
          "port": "8080",
          "path": ["api", "orders", "{{orderId}}", "status"]
        },
        "description": "Expected: 409 Conflict. Transitioning an order from CREATED directly to SHIPPED is illegal. Replace orderId with a valid order UUID in CREATED status."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 409\", function () {",
              "    pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
