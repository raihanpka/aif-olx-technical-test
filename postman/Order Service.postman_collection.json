{
  "info": {
    "name": "Order Service",
    "description": "Postman collection for the Order Service API. This collection covers all CRUD operations, status transitions, sorting, pagination, and error scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has orderId\", function () {",
              "    pm.response.to.have.jsonBody(\"orderId\");",
              "});",
              "pm.test(\"Status is CREATED\", function () {",
              "    pm.expect(pm.response.json().status).to.eql(\"CREATED\");",
              "});",
              "pm.test(\"Total amount is computed\", function () {",
              "    pm.expect(pm.response.json().totalAmount).to.eql(\"3.70\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Andi Wijaya\",\n  \"items\": [\n    {\n      \"productName\": \"Apple\",\n      \"quantity\": 3,\n      \"unitPrice\": 0.50\n    },\n    {\n      \"productName\": \"Bread Loaf\",\n      \"quantity\": 1,\n      \"unitPrice\": 2.20\n    }\n  ]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders",
          "host": ["http", "localhost"],
          "port": "8080",
          "path": ["api", "orders"]
        },
        "description": "Creates a new order. The server generates orderId, sets status to CREATED, and computes totalAmount from line items."
      }
    },
    {
      "name": "Create Order With Empty Items",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Andi Wijaya\",\n  \"items\": []\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders",
          "host": ["http", "localhost"],
          "port": "8080",
          "path": ["api", "orders"]
        },
        "description": "Expected: 400 Bad Request because order must have at least one line item."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
