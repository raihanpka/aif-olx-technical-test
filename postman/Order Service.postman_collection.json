    {
      "name": "Cancel Order",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"CANCELLED\",\n  \"cancellationReason\": \"Customer requested cancellation\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/orders/{{orderId}}/status",
          "host": ["http", "localhost"],
          "port": "8080",
          "path": ["api", "orders", "{{orderId}}", "status"]
        },
        "description": "Cancels an order. Requires a cancellation reason. Can be performed from CREATED, PAID, or SHIPPED status. Replace orderId with a valid order UUID."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Status is CANCELLED\", function () {",
              "    pm.expect(pm.response.json().status).to.eql(\"CANCELLED\");",
              "});",
              "pm.test(\"Cancellation reason is saved\", function () {",
              "    pm.expect(pm.response.json().cancellationReason).to.eql(\"Customer requested cancellation\");",
              "});"
            ]
          }
        }
      ]
    },
