meta {
  name: Create Order With Negative Quantity
  method: POST
  url: {{baseUrl}}/api/orders
  type: http
}

post {
  url: {{baseUrl}}/api/orders
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "customerName": "Andi Wijaya",
    "items": [
      { "productName": "Apple", "quantity": -1, "unitPrice": 0.50 }
    ]
  }
}

tests {
  test("Status code is 400", function() {
    expect(res.getStatus()).to.equal(400);
  });
}
